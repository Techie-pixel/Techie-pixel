<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="850" height="420" viewBox="0 0 850 420">
    <style>
        .font { 
            font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace; 
            font-size: 15px; 
            font-weight: 500;
        }
        .bg { fill: #0d1117; }
        .frame { stroke: #30363d; stroke-width: 1.5; }
        .text { fill: #c9d1d9; }
        .header { fill: #8b949e; font-size: 14px; }
        .prompt { fill: #a78bfa; font-weight: 600; }
        .cmd { fill: #06b6d4; font-weight: 600; }
        .task { fill: #8b949e; }
        .success { fill: #2ea043; font-weight: 600;}
        .pass { fill: #2ea043; font-weight: 600;}
        .done { fill: #06b6d4; font-weight: 600;}
        .highlight1 { fill: #f59e0b; font-weight: 600;}
        .highlight2 { fill: #a78bfa; font-weight: 600;}
        .cursor { fill: #06b6d4; }
    </style>

    <!-- UI Background Box -->
    <rect width="848" height="418" x="1" y="1" rx="10" ry="10" class="bg frame"/>
    
    <!-- Mac Window Buttons -->
    <circle cx="20" cy="20" r="6" fill="#ff5f56"/>
    <circle cx="40" cy="20" r="6" fill="#ffbd2e"/>
    <circle cx="60" cy="20" r="6" fill="#28c840"/>
    
    <!-- Terminal Title -->
    <text x="360" y="24" class="font header">bash - aditya@dev: ~</text>
    
    <!-- Header Separator Line -->
    <line x1="0" y1="40" x2="850" y2="40" class="frame"/>

    <!-- Terminal Content Area -->
    <g class="font" transform="translate(25, 75)">
        
        <!-- Line 1: The typed command -->
        <clipPath id="type1">
            <rect x="0" y="-15" height="25" width="0">
                <animate attributeName="width" values="0; 0; 800; 800; 0" keyTimes="0; 0.035; 0.092; 0.985; 1" dur="14s" repeatCount="indefinite" />
            </rect>
        </clipPath>
        <text x="0" y="0" clip-path="url(#type1)">
            <tspan class="prompt">aditya@dev:~$</tspan> <tspan class="cmd">java Goodbye.class --run</tspan>
        </text>

        <!-- Line 2: Task 1 (Wait: 1.8s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.128; 0.129; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="35" class="task">task 1/5 &gt; Compiling gratitude........</text>
        </g>
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.164; 0.165; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="360" y="35" class="success">[SUCCESS] ✓</text>
        </g>

        <!-- Line 3: Task 2 (Wait: 2.6s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.185; 0.186; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="65" class="task">task 2/5 &gt; Linking appreciation.......</text>
        </g>
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.214; 0.215; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="360" y="65" class="success">[SUCCESS] ✓</text>
        </g>

        <!-- Line 4: Task 3 (Wait: 3.3s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.235; 0.236; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="95" class="task">task 3/5 &gt; Deploying thanks...........</text>
        </g>
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.264; 0.265; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="360" y="95" class="success">[SUCCESS] ✓</text>
        </g>

        <!-- Line 5: Task 4 (Wait: 4.0s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.285; 0.286; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="125" class="task">task 4/5 &gt; Running kindness checks....</text>
        </g>
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.314; 0.315; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="360" y="125" class="pass">[PASS] ✓</text>
        </g>

        <!-- Line 6: Task 5 (Wait: 4.7s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.335; 0.336; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="155" class="task">task 5/5 &gt; Finalizing goodbye pipeline</text>
        </g>
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.371; 0.372; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="360" y="155" class="done">[DONE] ✓</text>
        </g>

        <!-- Line 7: BUILD SUCCESSFUL (Wait: 5.8s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.414; 0.415; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="195" class="success">BUILD SUCCESSFUL ✅</text>
        </g>

        <!-- Line 8: Thank you (Typed: 6.5s to 7.5s) -->
        <clipPath id="type2">
            <rect x="0" y="220" height="25" width="0">
                <animate attributeName="width" values="0; 0; 800; 800; 0" keyTimes="0; 0.464; 0.535; 0.985; 1" dur="14s" repeatCount="indefinite" />
            </rect>
        </clipPath>
        <text x="0" y="235" class="highlight1" clip-path="url(#type2)">&gt;&gt; Thank you for visiting my profile! 🚀</text>

        <!-- Line 9: Happy Coding (Typed: 8.2s to 9.2s) -->
        <clipPath id="type3">
            <rect x="0" y="250" height="25" width="0">
                <animate attributeName="width" values="0; 0; 800; 800; 0" keyTimes="0; 0.585; 0.657; 0.985; 1" dur="14s" repeatCount="indefinite" />
            </rect>
        </clipPath>
        <text x="0" y="265" class="highlight2" clip-path="url(#type3)">&gt;&gt; Happy Coding &amp; Keep Shipping! 💻</text>

        <!-- Line 10: Final Prompt & Cursor (Wait: 9.8s) -->
        <g opacity="0">
            <animate attributeName="opacity" values="0; 0; 1; 1; 0" keyTimes="0; 0.700; 0.701; 0.985; 1" dur="14s" repeatCount="indefinite" />
            <text x="0" y="305" class="prompt">aditya@dev:~$</text>
            <!-- Blinking Cursor -->
            <rect x="120" y="291" width="9" height="16" class="cursor">
                <animate attributeName="opacity" values="1; 0; 1" keyTimes="0; 0.5; 1" dur="1s" repeatCount="indefinite" />
            </rect>
        </g>
    </g>
</svg>
